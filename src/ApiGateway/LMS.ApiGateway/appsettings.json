{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "lms-super-secret-jwt-key-min-32-chars-here!!",
    "Issuer": "LMS.Identity",
    "Audience": "LMS.Client"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "auth-versioned-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/v{version}/auth/{**catch-all}"
        }
      },
      "students-route": {
        "ClusterId": "student-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/students/{**catch-all}"
        }
      },
      "students-versioned-route": {
        "ClusterId": "student-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v{version}/students/{**catch-all}"
        }
      },
      "courses-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/courses/{**catch-all}"
        }
      },
      "courses-versioned-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v{version}/courses/{**catch-all}"
        }
      },
      "subjects-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/subjects/{**catch-all}"
        }
      },
      "subjects-versioned-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v{version}/subjects/{**catch-all}"
        }
      },
      "semesters-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/semesters/{**catch-all}"
        }
      },
      "semesters-versioned-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v{version}/semesters/{**catch-all}"
        }
      },
      "enrollments-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/enrollments/{**catch-all}"
        }
      },
      "enrollments-versioned-route": {
        "ClusterId": "course-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/v{version}/enrollments/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://identity-service:8080/"
          }
        }
      },
      "student-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://student-service:8080/"
          }
        }
      },
      "course-cluster": {
        "Destinations": {
          "d1": {
            "Address": "http://course-service:8080/"
          }
        }
      }
    }
  }
}

