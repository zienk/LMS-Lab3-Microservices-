{
  "info": {
    "name": "LMS Lab 3 Microservices",
    "description": "Lab 3 collection for Identity, Student, Course, API Gateway, JWT, and Course-to-Student gRPC enrollment flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 Login admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login returns 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "02 Refresh token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh-token",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "refresh-token"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('refresh returns 200', function () { pm.response.to.have.status(200); });",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('accessToken', json.data.accessToken);",
              "pm.collectionVariables.set('refreshToken', json.data.refreshToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "03 Unauthorized request returns 401",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/students?page=1&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "students"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('gateway rejects missing JWT', function () { pm.response.to.have.status(401); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "04 Students v1 protected",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/students?page=1&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('students v1 returns 200', function () { pm.response.to.have.status(200); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "05 Students v2 protected",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v2/students?page=1&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v2",
            "students"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      }
    },
    {
      "name": "06 Courses v1 protected",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/courses?page=1&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "courses"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    },
    {
      "name": "07 Subjects v1 protected",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects?page=1&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      }
    },
    {
      "name": "08 Semesters v1 protected",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/semesters?page=1&size=5",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "semesters"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "5"
            }
          ]
        }
      }
    },
    {
      "name": "09 Direct enrollment v1",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": 2,\n  \"courseId\": 1\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/enrollments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "enrollments"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('direct enrollment creates record', function () { pm.response.to.have.status(201); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "10 Course enrollment flow uses gRPC",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/courses/1/enroll",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "courses",
            "1",
            "enroll"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('course enrollment creates record through gRPC validation', function () { pm.response.to.have.status(201); });"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "11 Course enrollments",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{accessToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/courses/1/enrollments?page=1&size=10",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "courses",
            "1",
            "enrollments"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        }
      }
    }
  ]
}
